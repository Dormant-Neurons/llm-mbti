# Environment Variables Configuration
# Copy this file to .env and fill in your actual credentials

# OpenAI API Key
# Get this from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Stuff
ANTHROPIC_BASE_URL=your_anthropic_base_url_here
ANTHROPIC_SMALL_FAST_MODEL=claude-haiku-4-5
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_AUTH_TOKEN=your_anthropic_token_here

# HuggingFace Token
# Get this from: https://huggingface.co/settings/tokens
HF_TOKEN=your_hf_token_here

# Weights & Biases Project (optional)
# Default: persona-vectors
WANDB_PROJECT=persona-vectors